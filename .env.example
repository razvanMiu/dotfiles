# Bitwarden Secrets Manager
# Prefer setting BWS_ACCESS_TOKEN in your shell/session if you do not want it on disk.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=
# BWS_SERVER_URL=

# Required Bitwarden secret key reference.
# Fails if SECRET_KEY is missing or duplicated in the configured project.
# EXAMPLE_REQUIRED_SECRET=bws:SECRET_KEY

# Optional Bitwarden secret key reference.
# Unsets EXAMPLE_OPTIONAL_SECRET if OPTIONAL_SECRET_KEY is missing.
# EXAMPLE_OPTIONAL_SECRET=bws?:OPTIONAL_SECRET_KEY
