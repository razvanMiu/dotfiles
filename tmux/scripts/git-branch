#!/bin/sh
# Print the current git branch for tmux status. Silent outside git repos.
# Appends * when the worktree has uncommitted changes.
# Usage: git-branch [path]

path=${1:-$PWD}

git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0

branch=$(git -C "$path" symbolic-ref --quiet --short HEAD 2>/dev/null) \
  || branch=$(git -C "$path" rev-parse --short HEAD 2>/dev/null) \
  || exit 0

[ -n "$branch" ] || exit 0

if ! git -C "$path" diff --quiet --ignore-submodules -- 2>/dev/null \
  || ! git -C "$path" diff --cached --quiet --ignore-submodules -- 2>/dev/null \
  || [ -n "$(git -C "$path" ls-files --others --exclude-standard 2>/dev/null)" ]; then
  branch="$branch*"
fi

printf '%s' "$branch"
